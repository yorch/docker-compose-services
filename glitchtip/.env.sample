GLITCHTIP_DOMAIN=glitchtip.example.com

# This needs to include the protocol and the port if it's not 80 or 443
GLITCHTIP_URL=http://glitchtip.example.com

GLITCHTIP_PORT=8000

# Suggested to run `openssl rand -hex 32` to generate a secret key
SECRET_KEY=secret-very-secret

EMAIL_FROM=me@domain.com

# STMP
# EMAIL_URL=smtp://email:password@smtp_url:port
EMAIL_HOST_USER=user
EMAIL_HOST_PASSWORD=password
EMAIL_HOST=domain.com
EMAIL_PORT="587 # 587 is the default for TLS"
EMAIL_USE_TLS=true

# (Default True) When True, any user will be able to register. When False, user self-signup is
# disabled after the first user is registered. Subsequent users must be created by a
# superuser on the backend and organization invitations may only be sent to existing users.
ENABLE_USER_REGISTRATION=false
# (Default False) When False, only superusers will be able to create new organizations after
# the first. When True, any user can create a new organization.
ENABLE_ORGANIZATION_CREATION=true

# Data Retention Settings
# (Default 90) Master default for all retention periods
GLITCHTIP_RETENTION_DAYS=90
# (Default GLITCHTIP_RETENTION_DAYS) Error event retention (hot + cold)
GLITCHTIP_EVENT_RETENTION_DAYS=90
# (Default 30) Days to keep events in PostgreSQL before archival
GLITCHTIP_EVENT_HOT_DAYS=30
# (Default GLITCHTIP_RETENTION_DAYS) Transaction retention (hot + cold)
GLITCHTIP_TRANSACTION_RETENTION_DAYS=180
# Log retention (hot + cold)
GLITCHTIP_LOG_RETENTION_DAYS=90
# (Default 7) Days to keep logs in PostgreSQL before archival
GLITCHTIP_LOG_HOT_DAYS=7
# (Default GLITCHTIP_RETENTION_DAYS) Uptime check retention
GLITCHTIP_UPTIME_RETENTION_DAYS=90
# (Default GLITCHTIP_RETENTION_DAYS) File (sourcemap, debug symbol) retention
GLITCHTIP_FILE_RETENTION_DAYS=90
# (Default 365) Release retention
GLITCHTIP_RELEASE_RETENTION_DAYS=365

# Hot/cold storage architecture. Recent data lives in PostgreSQL (hot) for fast queries.
# Older data is archived to Parquet files on S3 or the local filesystem (cold), queryable via
# DuckDB. This enables longer retention without growing your PostgreSQL database
GLITCHTIP_ENABLE_DUCKDB=false

# S3 bucket for cold storage. Defaults to AWS_STORAGE_BUCKET_NAME if set. Files use a cold_storage/ prefix.
GLITCHTIP_COLD_STORAGE_BUCKET=
# Local filesystem directory for cold storage (alternative to S3)
GLITCHTIP_COLD_STORAGE_DIR=

# Memory limit for DuckDB queries. Prevents OOM during archival by spilling to disk. Set to empty string to disable.
DUCKDB_MEMORY_LIMIT=128MB
# Writable directory for DuckDB spill-to-disk
DUCKDB_TEMP_DIRECTORY=/tmp
# Path to pre-installed DuckDB extensions (pre-installed in Docker image at /opt/duckdb/extensions)
DUCKDB_EXTENSION_DIRECTORY=

# (Default True) When True, GlitchTip deletes expired cold storage files. Set to False if using S3 lifecycle policies for cleanup instead.
GLITCHTIP_COLD_STORAGE_CLEANUP_ENABLED=true

# Database
POSTGRES_DB=glitchtip
POSTGRES_USER=glitchtip
POSTGRES_PASSWORD=glitchtip

# Database backup settings
DBBACKUPS_HEALTHCHECK_PORT=8080
DBBACKUPS_SCHEDULE=@daily
DBBACKUPS_BACKUP_KEEP_DAYS=7
DBBACKUPS_BACKUP_KEEP_WEEKS=4
DBBACKUPS_BACKUP_KEEP_MONTHS=6
